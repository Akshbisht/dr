@torch.no_grad()
def select_diverse_ensemble(ckpt_pool, snap_pool, val_loader, n=5):
    dw, all_cand = CFG["ensemble_diversity_weight"], ckpt_pool + snap_pool
    seen, unique = set(), []
    for qv, ev, sd in sorted(all_cand, key=lambda x: x[0], reverse=True):
        if ev not in seen: unique.append((qv, ev, sd)); seen.add(ev)
        if len(unique) >= 10: break
    if len(unique) <= n: return unique
    print(f"  🔀 Diversity selection: {len(unique)} candidates...")
    preds_map = {}
    for qv, ev, sd in unique:
        m_ = SG_CViT(CFG["num_classes"]).to(DEVICE)
        m_.load_state_dict({k.replace("module.",""): v for k,v in sd.items()}, strict=True)
        _, preds, _ = run_val(m_, val_loader, n=1)
        preds_map[ev] = preds; del m_; torch.cuda.empty_cache()
    ep_ord, qwk_map = [u[1] for u in unique], {u[1]: u[0] for u in unique}
    sel, rem = [ep_ord[0]], ep_ord[1:]
    while len(sel) < n and rem:
        bs, be = -1, None
        for ep_ in rem:
            div = np.mean([np.mean(preds_map[ep_]!=preds_map[s]) for s in sel])
            sc = (1-dw)*qwk_map[ep_] + dw*div
            if sc > bs: bs, be = sc, ep_
        sel.append(be); rem.remove(be)
    return [(qwk_map[ev], ev, sd) for (qv,ev,sd) in unique if ev in sel]

print("\n  🤖 Building diverse ensemble...")
ens_pool = select_diverse_ensemble(ckpt_pool, snap_pool, val_loader, n=5)

@torch.no_grad()
def ensemble_predict(pool, loader, n_tta=5):
    all_p, all_l, total_w = [], [], sum(p[0] for p in pool)
    for imgs, lbls, _ in loader:
        mp = []
        for qv, ev, sd in pool:
            m_ = SG_CViT(CFG["num_classes"]).to(DEVICE)
            m_.load_state_dict({k.replace("module.",""): v for k,v in sd.items()}, strict=True)
            m_.eval()
            mp.append(tta_predict(m_, imgs.to(DEVICE), n=n_tta) * qv)
            del m_; torch.cuda.empty_cache()
        all_p.append(torch.stack(mp).sum(0)/total_w); all_l.append(lbls.numpy())
    return np.vstack(all_p), np.concatenate(all_l)

