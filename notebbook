class CBAM(nn.Module):
    def __init__(self, channels, reduction=8, spatial_kernel=7):
        super().__init__()
        self.avg_ch, self.max_ch = nn.AdaptiveAvgPool2d(1), nn.AdaptiveMaxPool2d(1)
        self.fc_ch = nn.Sequential(nn.Linear(channels, channels//reduction, bias=False), nn.ReLU(), nn.Linear(channels//reduction, channels, bias=False))
        self.conv_sp = nn.Conv2d(2, 1, kernel_size=spatial_kernel, padding=spatial_kernel//2, bias=False)
    def forward(self, x):
        b, c, _, _ = x.shape
        ch = torch.sigmoid(self.fc_ch(self.avg_ch(x).view(b,c)) + self.fc_ch(self.max_ch(x).view(b,c))).view(b,c,1,1)
        x = x * ch
        sp = torch.sigmoid(self.conv_sp(torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)))
        return x * sp + x

class ChannelSE1D(nn.Module):
    def __init__(self, dim=384, reduction=8):
        super().__init__()
        self.se = nn.Sequential(nn.Linear(dim, dim//reduction), nn.ReLU(), nn.Linear(dim//reduction, dim), nn.Sigmoid())
    def forward(self, x): return x * self.se(x) + x

class GeMPool(nn.Module):
    def __init__(self, p=3.0, eps=1e-6):
        super().__init__()
        self.p = nn.Parameter(torch.ones(1)*p); self.eps = eps
    def forward(self, x): return F.avg_pool2d(x.clamp(min=self.eps).pow(self.p), (x.size(-2), x.size(-1))).pow(1.0/self.p)

class BiDirCrossAttentionFusion(nn.Module):
    def __init__(self, dim=384, heads=4, dropout=0.15):
        super().__init__()
        self.nc, self.nv = nn.LayerNorm(dim), nn.LayerNorm(dim)
        self.attn_cv = nn.MultiheadAttention(dim, heads, dropout=dropout, batch_first=True)
        self.attn_vc = nn.MultiheadAttention(dim, heads, dropout=dropout, batch_first=True)
        self.gate = nn.Sequential(nn.Linear(dim*2, dim), nn.Sigmoid())
        self.ffn = nn.Sequential(nn.Linear(dim, dim*2), nn.GELU(), nn.Dropout(dropout), nn.Linear(dim*2, dim))
        self.no, self.proj, self.drop = nn.LayerNorm(dim), nn.Linear(dim, dim), nn.Dropout(dropout)
    def forward(self, c, v):
        cn, vn = self.nc(c).unsqueeze(1), self.nv(v).unsqueeze(1)
        cv = self.attn_cv(cn, vn, vn)[0].squeeze(1)
        vc = self.attn_vc(vn, cn, cn)[0].squeeze(1)
        g = self.gate(torch.cat([cv, vc], dim=-1))
        x = self.no(c + g*cv + (1-g)*vc)
        return self.drop(self.proj(x + self.ffn(x)))

class SG_CViT(nn.Module):
    def __init__(self, nc=5):
        super().__init__()
        fpn_dim = CFG["fpn_out_dim"]
        self.cnn = timm.create_model("efficientnet_b4", pretrained=True, features_only=True, out_indices=(2,3,4))
        cdims = self.cnn.feature_info.channels()
        self.lat3, self.lat2, self.lat1 = nn.Conv2d(cdims[2], fpn_dim, 1), nn.Conv2d(cdims[1], fpn_dim, 1), nn.Conv2d(cdims[0], fpn_dim, 1)
        self.cbam = CBAM(fpn_dim, reduction=8, spatial_kernel=7)
        self.gem1, self.gem2, self.gem3 = GeMPool(), GeMPool(), GeMPool()
        self.ms_proj = nn.Sequential(nn.Linear(fpn_dim*3, 384), nn.LayerNorm(384), nn.GELU())

        try:
            self.vit = timm.create_model("swin_base_patch4_window12_384", pretrained=True, num_classes=0, img_size=SZ)
            self._vd = 1024
        except:
            try:
                self.vit = timm.create_model("swin_base_patch4_window7_224", pretrained=True, num_classes=0, img_size=SZ, strict_img_size=False, dynamic_img_size=True)
                self._vd = 1024
            except:
                self.vit = timm.create_model("swin_tiny_patch4_window7_224", pretrained=True, num_classes=0, img_size=SZ)
                self._vd = 768

        self.vit_attn_pool = nn.Sequential(nn.Linear(self._vd, 128), nn.Tanh(), nn.Linear(128, 1))
        self.vit_proj = nn.Linear(self._vd, 384)
        self.fus = BiDirCrossAttentionFusion(384)
        self.norm = nn.LayerNorm(384)
        self.se_post = ChannelSE1D(384)
        self.dropout = nn.Dropout(0.20)
        self.head = nn.Linear(384, nc-1)
        self.cls_head = nn.Linear(384, nc)
        self.aux_head = nn.Linear(384, 1)

    def backbone_parameters(self): return list(self.cnn.parameters()) + list(self.vit.parameters())
    def head_parameters(self):
        bids = {id(p) for p in self.backbone_parameters()}
        return [p for p in self.parameters() if id(p) not in bids]

    def forward(self, x):
        f1, f2, f3 = self.cnn(x)
        p3 = self.lat3(f3)
        p2 = self.lat2(f2) + F.interpolate(p3, f2.shape[-2:], mode="bilinear", align_corners=False)
        p1 = self.lat1(f1) + F.interpolate(p2, f1.shape[-2:], mode="bilinear", align_corners=False)
        c = self.ms_proj(torch.cat([self.gem1(self.cbam(p1)).flatten(1), self.gem2(p2).flatten(1), self.gem3(p3).flatten(1)], dim=1))
        vr = self.vit.forward_features(x)
        if vr.ndim == 4: vr = vr.view(vr.shape[0], -1, self._vd)
        elif vr.ndim == 2: vr = vr.unsqueeze(1)
        aw = torch.softmax(self.vit_attn_pool(vr), dim=1)
        v = self.vit_proj((aw * vr).sum(1))
        fused = self.dropout(self.se_post(self.norm(self.fus(c, v))))
        return self.head(fused), self.cls_head(fused), self.aux_head(fused)

