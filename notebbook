    med = compute_metrics(vh, vp, vprob); gnorm = np.mean(gnorms) if gnorms else 0.0

    g1_f1, g1_sns, g1_prc, g2_sns = med.get("G1",{}).get("F1", 0.0), med.get("G1",{}).get("Sens",0.0), med.get("G1",{}).get("Prec", 0.0), med.get("G2",{}).get("Sens", 0.0)
    g3_f1, g3_sns, g3_prc = med.get("G3",{}).get("F1", 0.0), med.get("G3",{}).get("Sens",0.0), med.get("G3",{}).get("Prec", 0.0)
    prev_g1_boost, prev_g3_boost = dyn_g1_boost, dyn_g3_boost

    if (g1_f1 < CFG["g1_f1_floor"] or (g1_sns < CFG["g1_sens_floor"] and g1_prc < CFG["g1_prec_floor"])):
        dyn_g1_boost = min(dyn_g1_boost*CFG["g1_boost_step"], CFG["g1_sampler_boost_max"])
    elif g1_prc > CFG["g1_decay_prec_thresh"] and g1_sns > 0.55:
        dyn_g1_boost = max(dyn_g1_boost*CFG["g1_decay_rate"], 1.0)

    if (g3_f1 < CFG["g3_f1_floor"] or (g3_sns < CFG["g3_sens_floor"] and g3_prc < CFG["g3_prec_floor"])):
        dyn_g3_boost = min(dyn_g3_boost*CFG["g3_boost_step"], CFG["g3_sampler_boost_max"])
    elif g3_prc > CFG["g3_decay_prec_thresh"] and g3_sns > 0.55:
        dyn_g3_boost = max(dyn_g3_boost*CFG["g3_decay_rate"], 1.0)

    if abs(dyn_g1_boost-prev_g1_boost) > 0.001 or abs(dyn_g3_boost-prev_g3_boost) > 0.001:
        sampler = build_sampler(train_df, CFG["boundary_boost"], dyn_g1_boost, dyn_g3_boost)
        train_loader = make_loader(DRDataset(train_df, train_aug, strong_aug=strong_aug), CFG["batch_size"], sampler=sampler, drop_last=True)

    b1 = "↑" if dyn_g1_boost>prev_g1_boost else ("↓" if dyn_g1_boost<prev_g1_boost else "→")
    b3 = "↑" if dyn_g3_boost>prev_g3_boost else ("↓" if dyn_g3_boost<prev_g3_boost else "→")
    print_metrics(med, ep+1, qwk, mf1, dq, gnorm, swa.active,
                   f"G1[F1:{g1_f1:.3f} Sns:{g1_sns:.3f} Prc:{g1_prc:.3f}] G2:{g2_sns:.3f} G3[F1:{g3_f1:.3f} Sns:{g3_sns:.3f} Prc:{g3_prc:.3f}] | "
                   f"G1x:{dyn_g1_boost:.2f}{b1} G3x:{dyn_g3_boost:.2f}{b3} | HO:{'Yes' if is_head_only else 'No'}")

    if qwk > best_qwk:
        vh_t, vp_t, vpt = run_val(em, val_loader, n=CFG["tta_n_save"])
        best_qwk = cohen_kappa_score(vh_t, vp_t, weights="quadratic")
        best_probs, best_labels, pat_q = vpt.copy(), vh_t.copy(), 0
        torch.save(em.state_dict(), f"/kaggle/working/best_model_v245_{DATASET_MODE}_fold{FOLD_IDX}.pth")
        print(f"  💾 Saved (TTA×{CFG['tta_n_save']} QWK={best_qwk:.4f})")
    else: pat_q += 1

    if mf1 > best_f1: best_f1 = mf1; pat_f = 0
    else: pat_f += 1

    ckpt_pool.append((qwk, ep, copy.deepcopy(em.state_dict())))
    ckpt_pool.sort(key=lambda x: x[0], reverse=True)
    if len(ckpt_pool) > CFG["topk_checkpoints"]: ckpt_pool.pop()
    if ep in CFG["snapshot_epochs"]:
        snap_pool.append((qwk, ep, copy.deepcopy(em.state_dict())))
        print(f"  📸 Snapshot @ ep{ep+1} (QWK={qwk:.4f})")
    if pat_q >= CFG["patience"] and pat_f >= CFG["patience"]:
        print("  🛑 Early stop"); break
    if (ep+1) % 5 == 0: torch.save({"epoch": ep, "model": em.state_dict(), "qwk": best_qwk}, f"/kaggle/working/ckpt_ep{ep+1}_v245_{DATASET_MODE}_fold{FOLD_IDX}.pth")
    torch.cuda.empty_cache()

