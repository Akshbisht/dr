class EMA:
    def __init__(self, m, d): self.d = d; self.sh = copy.deepcopy(m); self.sh.eval()
    @torch.no_grad()
    def update(self, m):
        for s, p in zip(self.sh.parameters(), m.parameters()): s.data.mul_(self.d).add_(p.data, alpha=1-self.d)
    def get(self): return self.sh
    def set_decay(self, d): self.d = min(d, CFG["ema_decay_base"]-1e-7)

class SWA:
    def __init__(self, m, se): self.se = se; self.m = m; self.w = None; self.active = False; self.n = 0
    def update(self, ep):
        if ep < self.se: return
        sd = self.m.state_dict()
        if not self.active: self.w = {k: v.clone().float() for k, v in sd.items()}; self.active = True; self.n = 1
        else:
            self.n += 1
            for k, v in sd.items(): self.w[k] = (self.w[k]*(self.n-1) + v.float()) / self.n
    def apply(self, m):
        if self.w: m.load_state_dict({k: v.to(next(m.parameters()).dtype) for k, v in self.w.items()})
    @torch.no_grad()
    def update_bn(self, m, loader, device, n=50):
        m.train()
        for i, (x, _, _) in enumerate(loader):
            if i >= n: break
            m(x.to(device))
        m.eval()

