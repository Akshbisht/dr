def eval_testset(loader, name, ens_pool, T, thresh):
    if loader is None: return None
    print(f"\n  📊 Evaluating: {name}")
    probs, labels = ensemble_predict(ens_pool, loader, n_tta=CFG["tta_n_save"])
    probs_T = apply_temperature(probs, T)
    preds = apply_thresh_with_safety(probs_T, thresh)
    met = compute_metrics(labels, preds, probs_T)
    ece_raw = compute_ece(probs, labels, CFG["ece_n_bins"])
    ece_cal = compute_ece(probs_T, labels, CFG["ece_n_bins"])
    _, lo, hi = bootstrap_ci(labels, preds, n=1000)
    obs, null, pv = perm_test(labels, preds, n=500)
    print(f"  QWK={met['QWK']:.4f} [{lo:.4f},{hi:.4f}] | Acc={met['Acc']:.4f} | F1={met['F1_macro']:.4f} | AUC={met.get('AUC',float('nan')):.4f}")
    print(f"  ECE: raw={ece_raw:.4f} -> calibrated={ece_cal:.4f} (T={T:.3f})")
    print(f"  Perm-p={pv:.4f} | null={null:.4f}")
    gap_str = "✅ HIT" if met['QWK'] >= 0.90 else f"❌ gap={0.90-met['QWK']:.4f}"
    print(f"  QWK>=0.90: {gap_str}")
    return {**met, "CI_lo": lo, "CI_hi": hi, "perm_null": null, "perm_p": pv, "ECE_raw": round(ece_raw,4), "ECE_calibrated": round(ece_cal,4)}

