def load_and_standardize(df, id_kw, diag_kw, img_dir, patient_split=False, source_name="unknown"):
    df = df.copy()
    df.columns = [c.strip().lower() for c in df.columns]
    id_col   = next((c for k in id_kw   for c in df.columns if k.lower() in c), None)
    diag_col = next((c for k in diag_kw for c in df.columns if k.lower() in c), None)
    if id_col is None or diag_col is None: return None
    
    df = df.rename(columns={id_col: "id_code", diag_col: "diagnosis"})
    df["id_code"]   = df["id_code"].astype(str).str.strip()
    df["diagnosis"] = pd.to_numeric(df["diagnosis"], errors="coerce")
    df = df.dropna(subset=["diagnosis"])
    df["diagnosis"] = df["diagnosis"].astype(int).clip(0, 4)

    def _path(code):
        base = code.split(".")[0]
        for ext in (".png", ".jpg", ".jpeg"):
            p = img_dir / f"{base}{ext}"
            if p.exists(): return str(p)
        return None

    df["path"]       = df["id_code"].apply(_path)
    df               = df.dropna(subset=["path"]).reset_index(drop=True)
    df["patient_id"] = (df["id_code"].apply(lambda x: x.split("_")[0]) if patient_split else df["id_code"])
    df["source"]     = source_name
    return df[["path", "diagnosis", "patient_id", "source"]]

def apply_balancing(df, mode):
    print(f"\n  🛠️ Applying balancing for mode: {mode}")
    if mode == "APTOS":
        caps = {0: 9999, 1: 9999, 2: 9999, 3: 9999, 4: 9999}
        desc = "No caps: Keeping 100% of APTOS data."
    elif mode == "EYEPACS":
        caps = {0: 6000, 1: 9999, 2: 4000, 3: 9999, 4: 9999}
        desc = "Aggressive cap on G0/G2 to prevent memorization of noise."
    elif mode == "MESSIDOR_IDRID":
        caps = {0: 9999, 1: 9999, 2: 9999, 3: 9999, 4: 9999}
        desc = "No caps: Datasets are naturally balanced/small."
    else:
        caps = {i: 9999 for i in range(5)}
        desc = "Default: No caps."

    print(f"  Strategy: {desc}")
    balanced_frames = []
    for grade, cap in caps.items():
        sub = df[df["diagnosis"] == grade]
        if len(sub) > cap:
            sub = sub.sample(n=cap, random_state=123)
            print(f"    G{grade}: Capped to {cap:,}")
        else:
            print(f"    G{grade}: Kept all {len(sub):,}")
        balanced_frames.append(sub)
    return pd.concat(balanced_frames, ignore_index=True)

