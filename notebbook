def build_optimizer(model, base_lr, weight_decay):
    decay, groups, stage_ids = CFG["swin_layer_decay"], [], set()
    backbone_lr = base_lr 
    for i in range(4):
        lr_i = backbone_lr * (decay**(3-i))
        params = [p for n, p in model.vit.named_parameters() if f"layers.{i}" in n and p.requires_grad]
        if params:
            groups.append({"params": params, "lr": lr_i, "initial_lr": lr_i, "name": f"swin_s{i}"})
            stage_ids.update(id(p) for p in params)
    vit_other = [p for n, p in model.vit.named_parameters() if id(p) not in stage_ids and p.requires_grad]
    if vit_other: groups.append({"params": vit_other, "lr": backbone_lr*0.5, "initial_lr": backbone_lr*0.5, "name": "swin_other"})
    cnn_p = [p for p in model.cnn.parameters() if p.requires_grad]
    if cnn_p: groups.append({"params": cnn_p, "lr": backbone_lr, "initial_lr": backbone_lr, "name": "cnn"})
    bids = {id(p) for p in model.backbone_parameters()}
    head_p = [p for p in model.parameters() if id(p) not in bids and p.requires_grad]
    if head_p: groups.append({"params": head_p, "lr": CFG["head_lr"], "initial_lr": CFG["head_lr"], "name": "heads"})
    return torch.optim.AdamW(groups, weight_decay=weight_decay)

