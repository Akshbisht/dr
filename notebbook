def circle_crop(img: np.ndarray) -> np.ndarray:
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    _, th = cv2.threshold(gray, 10, 255, cv2.THRESH_BINARY)
    coords = cv2.findNonZero(th)
    if coords is None:
        h, w = img.shape[:2]; m = min(h, w)
        return img[(h-m)//2:(h-m)//2+m, (w-m)//2:(w-m)//2+m]
    x, y, w, h = cv2.boundingRect(coords)
    return img[y:y+h, x:x+w]

def dr_preprocess(img: np.ndarray) -> np.ndarray:
    img_f   = img.astype(np.float32)
    h, w    = img_f.shape[:2]
    sigma   = int(np.clip(0.02 * min(h, w), 5, 10))
    blurred = cv2.GaussianBlur(img_f, (0, 0), sigma)
    result  = np.clip(cv2.addWeighted(img_f, 4.0, blurred, -4.0, 128), 0, 255).astype(np.uint8)
    lab     = cv2.cvtColor(result, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    l       = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8)).apply(l)
    result  = cv2.cvtColor(cv2.merge((l, a, b)), cv2.COLOR_LAB2BGR)
    result[:, :, 1] = cv2.createCLAHE(clipLimit=1.5, tileGridSize=(8, 8)).apply(result[:, :, 1])
    return result

