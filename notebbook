def corn_loss_uniform(logits, targets, smoothing=0.05):
    nc, L, cnt = logits.shape[1]+1, torch.zeros(1, device=logits.device), 0
    for k in range(1, nc):
        mask = targets >= (k-1)
        if mask.sum() == 0: continue
        sl, st = logits[mask, k-1], (targets[mask] >= k).float()
        ss = st*(1-smoothing) + (1-st)*smoothing
        L = L + F.binary_cross_entropy_with_logits(sl, ss, reduction="mean")
        cnt += 1
    return L / max(cnt, 1)

def compute_loss(corn_lg, cls_lg, aux_lg, targets, cb_w, head_only=False):
    l_corn = corn_loss_uniform(corn_lg, targets, smoothing=CFG["corn_smoothing"])
    l_aux = F.binary_cross_entropy_with_logits(aux_lg.float(), (targets>0).float().unsqueeze(1))
    
    # [FIX v24.5] Reintroduce mild class weights to CE loss. 
    # The sampler handles frequency; the loss must handle gradient magnitude.
    # Capping at 3.0 prevents the explosions seen in earlier versions.
    mild_cb_w = cb_w.clamp(max=3.0)
    l_ce = F.cross_entropy(cls_lg.float(), targets, weight=mild_cb_w, label_smoothing=0.1)
    
    if head_only:
        total = CFG["head_only_corn_w"] * l_corn + CFG["head_only_aux_w"] * l_aux
    else:
        total = (CFG["corn_weight"] * l_corn + CFG["ce_weight"] * l_ce)
    return total if torch.isfinite(total) else torch.tensor(0.0, device=corn_lg.device, requires_grad=True)

def compute_loss_mixup(corn_lg, cls_lg, aux_lg, la, lb, lam, cb_w, head_only=False):
    if lb is None: return compute_loss(corn_lg, cls_lg, aux_lg, la, cb_w, head_only)
    return lam * compute_loss(corn_lg, cls_lg, aux_lg, la, cb_w, head_only) + (1-lam) * compute_loss(corn_lg, cls_lg, aux_lg, lb, cb_w, head_only)

