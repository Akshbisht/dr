class DRDataset(Dataset):
    def __init__(self, df, aug, has_label=True, strong_aug=None):
        self.df, self.aug, self.hl, self.strong_aug = df.reset_index(drop=True), aug, has_label, strong_aug
    def __len__(self): return len(self.df)
    def __getitem__(self, idx):
        row = self.df.iloc[idx]; img = cv2.imread(str(row["path"]))
        if img is None: img = np.zeros((SZ,SZ,3), dtype=np.uint8)
        img = circle_crop(img)
        h, w = img.shape[:2]
        if max(h, w) > 640: img = cv2.resize(img, (int(w*640/max(h,w)), int(h*640/max(h,w))), interpolation=cv2.INTER_AREA)
        img = dr_preprocess(img); img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        use_strong = self.strong_aug is not None and bool(row.get("use_strong_aug", False))
        img = (self.strong_aug if use_strong else self.aug)(image=img)["image"]
        t = torch.tensor(img, dtype=torch.float32).permute(2, 0, 1)
        return (t, int(row["diagnosis"]), str(row.get("source", "unknown"))) if self.hl else (t, -1, "unknown")

def collate_fn(batch):
    imgs, labels, sources = zip(*batch)
    return torch.stack(imgs), torch.tensor(labels), list(sources)

def apply_ordinal_mixup(imgs, labels, alpha=0.20):
    if alpha <= 0 or random.random() > CFG["mixup_prob"]: return imgs, labels, None, 1.0
    lam = float(np.random.beta(alpha, alpha)); B = imgs.size(0); pid = torch.arange(B, device=imgs.device)
    for i in range(B):
        cands = [j for j in range(B) if abs(labels[j].item() - labels[i].item()) <= 1 and j != i]
        if cands: pid[i] = random.choice(cands)
    return lam*imgs + (1-lam)*imgs[pid], labels, labels[pid], lam

