def tta_predict(mdl, imgs, n=5):
    views = [imgs, imgs.flip(-1), imgs.flip(-2), torch.rot90(imgs,1,[-2,-1]), torch.rot90(imgs,3,[-2,-1])][:n]
    all_p = []
    for v in views:
        with torch.autocast("cuda", enabled=USE_AMP):
            lg = torch.clamp(mdl(v)[0], -CFG["logit_clamp"], CFG["logit_clamp"])
            sig = torch.sigmoid(lg).clamp(1e-3, 1-1e-3)
            geq = torch.cumprod(sig, dim=1)
            prob = torch.clamp(torch.cat([1.0 - geq[:, 0:1], geq[:, :-1] - geq[:, 1:], geq[:, -1:]], dim=1), min=1e-7)
        all_p.append(prob.cpu())
    return torch.stack(all_p).mean(0)

@torch.no_grad()
def run_val(mdl, loader, n=1):
    mdl.eval(); vh, vp, vprob = [], [], []
    for imgs, lbls, _ in loader:
        p = tta_predict(mdl, imgs.to(DEVICE), n=n)
        vh.append(lbls); vp.append(p.argmax(1)); vprob.append(p)
    return torch.cat(vh).numpy(), torch.cat(vp).numpy(), torch.cat(vprob).numpy()

