def head_lr_mul(step):
    wu = CFG["head_warmup_epochs"] * steps_per_epoch_approx
    if step < wu: return (step+1) / max(1, wu)
    t = (step-wu) / max(1, wu)
    return CFG["min_lr"]/CFG["head_lr"] + (1 - CFG["min_lr"]/CFG["head_lr"])*0.5*(1+math.cos(math.pi*t))

def backbone_lr_mul(step):
    if step < backbone_warmup_steps: return (step+1) / max(1, backbone_warmup_steps)
    t = (step-backbone_warmup_steps) / max(1, backbone_total_steps-backbone_warmup_steps)
    return CFG["min_lr"]/CFG["base_lr"] + (1 - CFG["min_lr"]/CFG["base_lr"])*0.5*(1+math.cos(math.pi*t))

def set_lr_head(step):
    mul = head_lr_mul(step)
    for pg in optimizer.param_groups: pg["lr"] = pg.get("initial_lr", CFG["head_lr"]) * mul
    return CFG["head_lr"] * mul

def set_lr_full(step):
    mul = backbone_lr_mul(step)
    for pg in optimizer.param_groups: pg["lr"] = pg.get("initial_lr", CFG["base_lr"]) * mul
    return CFG["base_lr"] * mul

def apply_thresh(probs, t): return (np.cumsum(probs, 1)[:, :4] < (1.0-np.asarray(t))).sum(1).astype(int)

def apply_thresh_with_safety(probs, t):
    preds = apply_thresh(probs, t)
    confident_g0 = probs[:, 0] > CFG["g0_confidence_thresh"]
    unlikely_g1 = probs[:, 1] < 0.15
    preds[confident_g0 & unlikely_g1] = 0
    return preds

def apply_temperature(probs, T):
    lp = np.log(np.clip(probs, 1e-8, 1.0)) / T; lp -= lp.max(1, keepdims=True)
    p = np.exp(lp); return p/p.sum(1, keepdims=True)

def optimize_temperature(probs, labels):
    lp = np.log(np.clip(probs, 1e-8, 1.0))
    def nll(T):
        s = lp/T; s -= s.max(1, keepdims=True); p = np.exp(s)/np.exp(s).sum(1, keepdims=True)
        return -np.mean(np.log(p[np.arange(len(labels)), labels]+1e-8))
    return float(minimize_scalar(nll, bounds=(0.5,3.0), method="bounded").x)

def calibrate_thresh(probs, labels, qwk_floor=0.85, g1_floor=0.35, g3_floor=0.30, apply_floors=True):
    acc_w, best = CFG["calib_acc_weight"], []
    for k in range(4):
        prev, fx = best[-1] if best else 0.05, best[:]
        def obj(t):
            c = (fx+[t]+[0.5]*(3-len(fx)))[:4]
            preds = apply_thresh(probs, c)
            q = cohen_kappa_score(labels, preds, weights="quadratic")
            acc = float(np.mean(labels==preds))
            if q < qwk_floor: return 1.0
            if apply_floors:
                if precision_score((labels==1).astype(int), (preds==1).astype(int), zero_division=0) < g1_floor: return 1.0
                if precision_score((labels==3).astype(int), (preds==3).astype(int), zero_division=0) < g3_floor: return 1.0
            return -(acc_w * acc + 0.15 * f1_score(labels, preds, average="macro", labels=list(range(5)), zero_division=0))
        best.append(minimize_scalar(obj, bounds=(max(prev,0.05), 0.70), method="bounded", options={"xatol":1e-3}).x)
    return best

def compute_ece(probs, labels, n_bins=15):
    conf = probs.max(1); preds = probs.argmax(1); correct = (preds == labels).astype(float)
    bins = np.linspace(0.0, 1.0, n_bins+1); ece, n = 0.0, len(labels)
    for lo, hi in zip(bins[:-1], bins[1:]):
        m = (conf > lo) & (conf <= hi) if lo > 0 else (conf >= lo) & (conf <= hi)
        if m.sum() == 0: continue
        ece += (m.sum()/n) * abs(correct[m].mean() - conf[m].mean())
    return float(ece)

def compute_metrics(y_true, y_pred, probs=None, nc=5):
    cm = confusion_matrix(y_true, y_pred, labels=list(range(nc))); out = {}
    for c in range(nc):
        tp, fp, fn = cm[c,c], cm[:,c].sum()-cm[c,c], cm[c,:].sum()-cm[c,c]
        tn = cm.sum()-tp-fp-fn
        out[f"G{c}"] = {"Sens": round(tp/(tp+fn+1e-9), 4), "Spec": round(tn/(tn+fp+1e-9), 4), "Prec": round(tp/(tp+fp+1e-9), 4), "F1": round(2*tp/(2*tp+fp+fn+1e-9), 4), "Sup": int(cm[c,:].sum())}
    out["QWK"] = round(cohen_kappa_score(y_true, y_pred, weights="quadratic"), 4)
    out["F1_macro"] = round(f1_score(y_true, y_pred, average="macro", labels=list(range(5)), zero_division=0), 4)
    out["Acc"] = round(float(np.mean(y_true==y_pred)), 4)
    if probs is not None:
        try:
            auc = roc_auc_score(np.eye(nc)[y_true], probs, multi_class="ovr", average=None)
            out["AUC_per"], out["AUC"] = [round(float(a),4) for a in auc], round(float(np.mean(auc)), 4)
        except: pass
    return out

def bootstrap_ci(y_true, y_pred, n=1000, alpha=0.05, seed=42):
    rng = np.random.default_rng(seed); ns = len(y_true); qs = []
    for _ in range(n):
        idx = rng.integers(0, ns, ns)
        qs.append(cohen_kappa_score(y_true[idx], y_pred[idx], weights="quadratic"))
    return float(np.mean(qs)), float(np.percentile(qs, 100*alpha/2)), float(np.percentile(qs, 100*(1-alpha/2)))

def perm_test(y_true, y_pred, n=500, seed=42):
    rng = np.random.default_rng(seed); obs = cohen_kappa_score(y_true, y_pred, weights="quadratic")
    null = [cohen_kappa_score(y_true, rng.permutation(y_pred), weights="quadratic") for _ in range(n)]
    return obs, float(np.mean(null)), float(np.mean(np.array(null)>=obs))

